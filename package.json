  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.169.0",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  }
