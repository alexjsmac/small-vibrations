{
  "name": "small-vibrations",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fingerprints": "tsx scripts/build-fingerprints.ts",
